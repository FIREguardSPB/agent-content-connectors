# Copy to .env (or run ./setup.sh to generate one with real secrets).
# NANGO_ENCRYPTION_KEY is base64 256-bit and CANNOT be changed once data exists.

# --- Encryption (openssl rand -base64 32) ---
NANGO_ENCRYPTION_KEY=

# --- Database (own instance, host port 5433 to avoid bot_postgres on 5432) ---
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=
NANGO_DB_NAME=nango
NANGO_DB_HOST=nango-db
NANGO_DB_PORT=5433

# --- Server / URLs ---
SERVER_PORT=3003
CONNECT_UI_PORT=3009
NANGO_SERVER_URL=http://localhost:3003
NANGO_PUBLIC_SERVER_URL=http://localhost:3003
NANGO_PUBLIC_CONNECT_URL=http://localhost:3009

# --- Dashboard basic auth ---
NANGO_DASHBOARD_USERNAME=admin
NANGO_DASHBOARD_PASSWORD=

LOG_LEVEL=info
