# Copy to mcp-server/.env and fill NANGO_SECRET_KEY (from the Nango dashboard).

# --- Nango connection ---
NANGO_HOST=http://localhost:3003
NANGO_CONNECT_UI_URL=http://localhost:3009
# Environment secret key from Nango dashboard (Environment Settings). NOT a platform token.
NANGO_SECRET_KEY=

# --- Per-platform Nango integration ids (providerConfigKey). Defaults shown. ---
NANGO_PROVIDER_YOUTUBE=youtube
NANGO_PROVIDER_INSTAGRAM=instagram
NANGO_PROVIDER_VK=vk

# --- Default connection ids per platform (from Connect UI / list_connected_accounts) ---
# Lets tools be called without passing connection_id every time.
NANGO_CONN_YOUTUBE=
NANGO_CONN_INSTAGRAM=
NANGO_CONN_VK=

# --- Optional ---
META_GRAPH_VERSION=v21.0
BROKER_HTTP_TIMEOUT=30
# DZEN_SESSION_PATH=~/.config/broker-connectors/dzen_session.json
